# =============================================================================
# REQUIRED — App will not start without these
# =============================================================================

# Supabase Postgres connection string
# Get from: Supabase Dashboard → Settings → Database → Connection string (URI)
# Use the "Transaction" pooler connection string, replace [YOUR-PASSWORD]
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# GitHub OAuth credentials
# Register at: https://github.com/settings/developers → New OAuth App
# Set callback URL to: http://localhost:8000/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback

# JWT secret — generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Must be at least 16 characters
JWT_SECRET=

# Encryption key for stored OAuth tokens
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Must be at least 32 characters. If you change this, all stored tokens become unreadable.
ENCRYPTION_KEY=

# Groq API key (free tier) — get at: https://console.groq.com/keys
GROQ_API_KEY=

# Voyage AI API key (free tier) — get at: https://dash.voyageai.com/api-keys
VOYAGE_API_KEY=

# =============================================================================
# OPTIONAL — Have sensible defaults
# =============================================================================

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
